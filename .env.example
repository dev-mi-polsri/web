BASE_URL="localhost:3000"

# Database Configuration
# Set DATABASE_TYPE to 'mysql' or 'postgres' (default: mysql)
DATABASE_TYPE=mysql

# MySQL Configuration (used when DATABASE_TYPE=mysql)
# Docker service: mysql (port 3306)
MYSQL_DATABASE=devdb
MYSQL_USER=devdb
MYSQL_PASSWORD=local_root_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_CONNECTION_LIMIT=10

# PostgreSQL Configuration (used when DATABASE_TYPE=postgres)
# Docker service: postgres (port 5432)
POSTGRES_URL=

# Atleast 32 characters long for better security
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app
BASE_URL=http://localhost:3000
